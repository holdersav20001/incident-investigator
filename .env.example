# ============================================================
# Incident Investigator — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ---- Database ---------------------------------------------------------------
# SQLite (development)
DATABASE_URL=sqlite:///./incidents.db
# PostgreSQL (production — replace with real credentials)
# DATABASE_URL=postgresql://incidents:incidents@localhost:5432/incidents

# ---- Application ------------------------------------------------------------
APP_ENV=development    # development | staging | production
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR

# ---- Evidence storage -------------------------------------------------------
EVIDENCE_ROOT=./evidence

# ---- LLM provider -----------------------------------------------------------
LLM_PROVIDER=mock      # "mock" for CI/dev, "anthropic" for production

# Anthropic API key — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=     # sk-ant-...

# Model to use for diagnosis and remediation planning
LLM_MODEL=claude-haiku-4-5-20251001
